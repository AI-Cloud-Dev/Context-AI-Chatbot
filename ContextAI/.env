# ── JWT Authentication ────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                    # Leave blank if no password set locally
REDIS_DB=0

# Chat memory: max messages to retain per user session
REDIS_CHAT_MEMORY_LIMIT=20

# Rate limiting: max requests per user per window
REDIS_RATE_LIMIT_MAX_REQUESTS=10
REDIS_RATE_LIMIT_WINDOW_SECONDS=60

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_store
CHROMA_COLLECTION_NAME=contextai_docs

# ── Ollama (Local LLM) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3                # Options: llama3, mistral, phi3, gemma

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2  # Sentence Transformers model name

# ── Document Processing ───────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
CHUNK_SIZE=500                     # Characters per text chunk
CHUNK_OVERLAP=50                   # Overlap between chunks

# ── FastAPI ───────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True                         # Set to False in production

# ── Streamlit ─────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000  # URL Streamlit uses to reach FastAPI
